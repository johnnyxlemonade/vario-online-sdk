{
  "name": "lemonade/vario-online-sdk",
  "description": "Typed PHP SDK for Vario Online API with immutable queries, dataset views and pluggable HTTP transport.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "vario",
    "vario-online",
    "erp",
    "sdk",
    "api",
    "psr-18",
    "php-sdk"
  ],
  "homepage": "https://github.com/johnnyxlemonade/vario-online-sdk",
  "support": {
    "issues": "https://github.com/johnnyxlemonade/vario-online-sdk/issues",
    "source": "https://github.com/johnnyxlemonade/vario-online-sdk"
  },
  "authors": [
    {
      "name": "Honza Mudrak",
      "email": "honzamudrak@gmail.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.1",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.0",
    "psr/http-message": "^1.1 || ^2.0",
    "guzzlehttp/guzzle": "^7.8"
  },
  "suggest": {
    "symfony/http-client": "Alternative PSR-18 HTTP client implementation",
    "nyholm/psr7": "Fast PSR-7 / PSR-17 implementation",
    "laminas/laminas-diactoros": "PSR-7 / PSR-17 implementation"
  },
  "autoload": {
    "psr-4": {
      "Lemonade\\Vario\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Lemonade\\Vario\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0 || ^11.0",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-strict-rules": "^2.0"
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "stan": "vendor/bin/phpstan analyse",
    "stan:ci": "vendor/bin/phpstan analyse --no-progress --memory-limit=1G"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "sort-packages": true
  }
}
